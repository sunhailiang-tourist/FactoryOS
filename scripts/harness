#!/usr/bin/env bash
# FactoryOS Harness 统一入口（SH-步步流 L0–L3）
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
if command -v uv >/dev/null 2>&1 && [[ -d "$ROOT/.venv" ]]; then
  exec uv run python "$ROOT/scripts/check_harness.py" "$@"
fi
if [[ -x "$ROOT/.venv/bin/python" ]]; then
  exec "$ROOT/.venv/bin/python" "$ROOT/scripts/check_harness.py" "$@"
fi
exec python3 "$ROOT/scripts/check_harness.py" "$@"
