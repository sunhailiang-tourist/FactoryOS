{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factoryos.local/schemas/PerceptionOutput/v1.0.0",
  "title": "PerceptionOutput",
  "description": "感知层结构化输出；agent_orchestrator 合并上下文后产出 DslPlan。",
  "type": "object",
  "required": [
    "skill_id",
    "intent_confidence",
    "modality_used",
    "steps",
    "clarifications",
    "perception_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "skill_id": { "type": "string" },
    "intent_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "modality_used": {
      "type": "array",
      "items": { "type": "string", "enum": ["voice", "image", "scan", "text"] },
      "minItems": 1
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/PlanStep" },
      "description": "拟议 DSL 步骤；须 ⊆ Skill.allowed_dsl ⊆ Graph.allowed_dsl"
    },
    "clarifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "question"],
        "properties": {
          "field": { "type": "string" },
          "question": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "perception_refs": {
      "type": "object",
      "properties": {
        "asr_transcript": { "type": ["string", "null"] },
        "ocr_text": { "type": ["string", "null"] },
        "media_object_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "PlanStep": {
      "type": "object",
      "required": ["verb", "params"],
      "additionalProperties": false,
      "properties": {
        "verb": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "params": { "type": "object" },
        "idempotency_key": { "type": ["string", "null"] }
      }
    }
  }
}
