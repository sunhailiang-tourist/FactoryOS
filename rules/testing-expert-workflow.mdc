  -H "Content-Type: application/json" \
  -d '{"login_type": 0, "phone": "<手机号>", "password": "<密码>"}' \
  | python3 -c "import sys,json; print(json.load(sys.stdin)['data']['access_token'])")

# Step 2: 用 token 访问（应成功）
