  -H "Content-Type: application/json" \
  -d '{"login_type": 0, "phone": "<手机号>", "password": "<密码>"}'

# 期望：result=0，返回 access_token + refresh_token
# 错误密码：result=2 (WRONG_PWD)
# 用户不存在：result=3 (USER_NOT_EXIST)
